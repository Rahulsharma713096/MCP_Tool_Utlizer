{
  "mcps": [
    {
      "id": "filesystem",
      "name": "Filesystem MCP",
      "type": "filesystem",
      "enabled": false,
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:\Users\hp\Projects\MCP_Tool_Utlizer\ai-workspace\docs"],
      "directory": "./workspace",
      "capabilities": ["create_directory", "write_file", "read_text_file", "list_directory", "search_files", "move_file", "get_file_info", "directory_tree"]
    },
    {
      "id": "browser",
      "name": "Browser MCP",
      "type": "browser",
      "enabled": false,
      "transport": "http",
      "endpoint": "http://localhost:3001",
      "capabilities": ["navigate", "click", "type", "extract"]
    },
    {
      "id": "github",
      "name": "GitHub MCP",
      "type": "github",
      "enabled": false,
      "transport": "http",
      "endpoint": "https://api.github.com",
      "capabilities": ["list_repos", "create_issue", "read_file", "search_code"]
    },
    {
      "id": "database",
      "name": "Database MCP",
      "type": "database",
      "enabled": false,
      "transport": "stdio",
      "command": "python",
      "args": ["mcps/database_mcp.py"],
      "capabilities": ["query", "insert", "update", "delete", "schema"]
    },
    {
      "id": "python-executor",
      "name": "Python Executor",
      "type": "python",
      "enabled": false,
      "transport": "stdio",
      "command": "python",
      "args": ["mcps/python_executor_mcp.py"],
      "capabilities": ["execute_python", "run_script", "install_package"]
    },
    {
      "id": "my-service",
      "name": "My GitHub MCP Service",
      "type": "custom",
      "enabled": false,
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@owner/my-service"],
      "github_repo": "owner/repo",
      "github_ref": "main",
      "root": "src/main/java",
      "exclude": ["**/vendor/**", "**/node_modules/**"],
      "capabilities": ["custom_service"]
    }
  ]
}

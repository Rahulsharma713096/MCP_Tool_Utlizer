# ===========================================
# AI Workspace Platform - Environment Config
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Application ---
APP_NAME=AI Workspace
APP_VERSION=1.0.0
DEBUG=true
ENV=development

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4

# --- Database ---
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./data/ai_workspace.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_workspace

# --- Security (REQUIRED: Change these in production!) ---
SECRET_KEY=change-this-to-a-secure-random-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
# Optional: Fernet encryption key (auto-generated from SECRET_KEY if not set)
# ENCRYPTION_KEY=

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=300

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Rate Limiting ---
RATE_LIMIT=100/minute

# --- Monitoring ---
ENABLE_METRICS=true
METRICS_PORT=9090

# --- Resource Limits ---
MAX_CPU_PERCENT=90.0
MAX_RAM_PERCENT=85.0
MODEL_IDLE_TIMEOUT_MINUTES=10
